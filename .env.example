# CI reviewer secrets for the jbaruch/coding-policy gh-aw PR review workflows.
# Set as GitHub Actions repository secrets:
#   https://github.com/jbaruch/nanoclaw-conferences/settings/secrets/actions
# The Codex (OpenAI-family) reviewer reads CODEX_API_KEY or OPENAI_API_KEY
# (CODEX_API_KEY wins when both are set). ANTHROPIC_API_KEY drives the Claude
# reviewer; TESSL_TOKEN authenticates the `tessl install` step for both.
CODEX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TESSL_TOKEN=

# Required environment for the check-cfps Sessionize pipeline.
#
# These keys are INJECTED INTO THE CONTAINER ENVIRONMENT by the NanoClaw host
# (the same keys the host already holds for its sessionize_* MCP tools) — the
# plugin does not load this file at runtime. This .env.example exists to document
# every required variable with a placeholder, per
# `jbaruch/coding-policy: no-secrets`. Never commit real key values.
#
# These are container-runtime secrets, not GitHub Actions secrets, so there is
# no repo Actions secret to link; CI does not need them (the test suite stubs
# all network calls).

# Sessionize speaker API key — open-CFP discovery (discover-open-cfps.py).
# Sent as the `X-API-KEY` header to https://sessionize.com/api/universal/open-cfps
SESSIONIZE_SPEAKER_KEY=your-sessionize-speaker-api-key

# Sessionize event API key — per-slug verification (verify-sessionize.py).
# Sent as the `X-API-KEY` header to https://sessionize.com/api/universal/event
SESSIONIZE_EVENT_API_KEY=your-sessionize-event-api-key

# Optional: override the Sessionize universal API base (tests / proxying).
# Defaults to https://sessionize.com/api/universal when unset.
# SESSIONIZE_API_BASE=https://sessionize.com/api/universal
